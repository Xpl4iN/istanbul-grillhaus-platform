# Database (Supabase)
# Pooler URL used by Prisma Client at runtime
DATABASE_URL="postgresql://postgres.<YOUR_PROJECT_REF>:<YOUR_PASSWORD>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
# Direct connection URL used by Prisma CLI (migrate, db push)
DIRECT_URL="postgresql://postgres.<YOUR_PROJECT_REF>:<YOUR_PASSWORD>@db.<YOUR_PROJECT_REF>.supabase.co:5432/postgres"

# Cloudflare Turnstile CAPTCHA
# Public site key (baked into the client bundle at build time)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"
# Secret key for server-side token verification
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# Admin PIN (optional, defaults to 123456 if not set)
# ADMIN_PIN="your-secure-pin"

# Seed route protection secret (optional)
# SEED_SECRET="your-seed-secret"
